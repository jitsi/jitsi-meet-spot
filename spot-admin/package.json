{
    "name": "spot-admin",
    "version": "0.0.1",
    "description": "Express mock/reference backend for Spot's optional backend mode (pairing, room info, calendar).",
    "license": "Apache-2.0",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/server.js",
        "start:dev": "tsx watch src/server.ts",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "dependencies": {
        "cors": "2.8.6",
        "dotenv": "17.4.2",
        "express": "5.2.1",
        "jwt-decode": "4.0.0"
    },
    "devDependencies": {
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/jest": "30.0.0",
        "@types/supertest": "7.2.0",
        "jest": "30.4.2",
        "supertest": "7.2.2",
        "ts-jest": "29.4.11",
        "tsx": "4.22.3"
    }
}
