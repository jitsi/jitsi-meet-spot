{
    "name": "spot-webdriver",
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "e2e": "wdio run wdio.conf.ts",
        "start-spot-client": "npm --prefix ../spot-client run start:dev",
        "ci": "start-server-and-test start-spot-client http://127.0.0.1:8000/ e2e",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "devDependencies": {
        "@types/jasmine": "6.0.0",
        "@wdio/cli": "9.27.2",
        "@wdio/globals": "9.27.2",
        "@wdio/jasmine-framework": "9.27.2",
        "@wdio/junit-reporter": "9.27.2",
        "@wdio/local-runner": "9.27.2",
        "@wdio/spec-reporter": "9.27.2",
        "@wdio/types": "9.27.2",
        "start-server-and-test": "3.0.5",
        "tsx": "4.22.3",
        "webdriverio": "9.27.2"
    }
}
