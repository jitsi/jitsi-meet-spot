{
    "name": "spot-electron",
    "version": "0.0.0",
    "description": "An electron application intended to be used to host a Spot-TV, to provide it additional functionality not available in browsers.",
    "author": {
        "name": "Jitsi Team",
        "email": "team@jitsi.org"
    },
    "productName": "Jitsi Spot",
    "repository": {
        "type": "git",
        "url": "git@github.com:jitsi/jitsi-meet-spot.git"
    },
    "license": "Apache-2",
    "type": "module",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "dist": "npm run build && electron-builder",
        "start": "npm run build && electron .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "dependencies": {
        "@jitsi/logger": "2.1.1",
        "electron-debug": "4.1.0",
        "electron-is-dev": "3.0.1",
        "electron-log": "5.4.4",
        "electron-updater": "6.8.9",
        "is-online": "12.0.2",
        "lodash": "4.18.1",
        "node-osascript": "2.1.0",
        "node-schedule": "2.1.1"
    },
    "devDependencies": {
        "@electron/notarize": "3.1.1",
        "@types/jest": "30.0.0",
        "@types/lodash": "4.17.24",
        "@types/node-schedule": "2.1.8",
        "electron": "42.4.0",
        "electron-builder": "26.15.3",
        "jest": "30.4.2",
        "ts-jest": "29.4.11"
    },
    "optionalDependencies": {
        "win-audio": "3.0.5"
    },
    "build": {
        "afterSign": "dist/scripts/notarize.js",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "src/static/**/*"
        ],
        "productName": "Spot",
        "appId": "org.jitsi.spot",
        "mac": {
            "category": "public.app-category.business",
            "entitlements": "entitlements.mac.plist",
            "entitlementsInherit": "entitlements.mac.plist",
            "gatekeeperAssess": false,
            "hardenedRuntime": true,
            "target": [
                {
                    "arch": "universal",
                    "target": "dmg"
                }
            ],
            "notarize": false,
            "extendInfo": {
                "NSCameraUsageDescription": "Camera access is required in order to make video-calls.",
                "NSMicrophoneUsageDescription": "Microphone access is required in order to make calls (audio/video)."
            }
        },
        "win": {
            "signtoolOptions": {
                "signingHashAlgorithms": ["sha256"],
                "sign": "dist/scripts/winSign.js"
            }
        },
        "publish": {
            "provider": "github",
            "private": false,
            "publishAutoUpdate": true
        }
    },
    "dmg": {
        "sign": false
    }
}
