{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ESNext",
        "jsx": "react-native",
        "lib": ["ESNext", "DOM"],
        "types": ["node", "jest"],
        "noEmit": true,
        "allowJs": false,
        "noImplicitOverride": false
    },
    "include": ["src", "App.tsx", "index.ts", "declarations.d.ts"]
}
