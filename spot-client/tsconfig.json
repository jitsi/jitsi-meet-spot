{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ES2022",
        "jsx": "react",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["node", "jest"],
        "paths": {
            "common/*": ["./src/common/*"],
            "spot-tv/*": ["./src/spot-tv/*"],
            "spot-remote/*": ["./src/spot-remote/*"]
        },
        "noEmit": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,

        "noImplicitOverride": false
    },
    "include": ["src", "setupTests.ts"]
}
